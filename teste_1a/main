import os
import json
import base64
import logging
import subprocess
import tempfile
from pathlib import Path
from typing import Any


import exiftool
import numpy as np
import requests
from PIL import Image, ImageChops
import io
import cv2


logger: logging.Logger = logging.getLogger(__name__)


TIPOS_IMAGEM: frozenset[str] = frozenset({
    ".jpg", ".jpeg", ".png", ".webp", ".heic", ".heif",
    ".tiff", ".tif", ".gif", ".bmp", ".raw",
})


TIPOS_VIDEO: frozenset[str] = frozenset({
    ".mp4", ".mov", ".avi", ".mkv", ".webm", ".flv", ".wmv", ".m4v",
})


CAMPOS_BINARIOS: frozenset[str] = frozenset({
    "item 0", "item 1", "item 2", "item 3",
    "item 1 sig tst 2 tst tokens val",
    "item 1r vals ocsp vals",
    "item 1 pad", "item 1 pad 2",
    "created assertions hash",
    "hash", "pad",
})


CAMPOS_IGNORADOS: frozenset[str] = frozenset({"sourcefile", "exiftoolversion"})


ELA_QUALIDADE: int = 90
ELA_FATOR_AMPLIFICACAO: int = 15
ELA_VALOR_MAX: int = 255


SERPAPI_URL: str = "https://serpapi.com/search"
SERPAPI_ENGINE: str = "google_reverse_image"
SERPAPI_MAX_RESULTADOS: int = 5


C2PA_TIMEOUT_S: int = 15


def _detectar_tipo(nome: str) -> str:
    ext = Path(nome).suffix.lower()
    if ext in TIPOS_IMAGEM:
        return "imagem"
    if ext in TIPOS_VIDEO:
        return "video"
    raise ValueError("Tipo nao suportado")


def _normalizar(dados: dict[str, Any]) -> dict[str, Any]:
    resultado: dict[str, Any] = {}
    for chave, valor in dados.items():
        chave_clean = chave.split(":")[-1]
        if chave_clean.lower() in CAMPOS_IGNORADOS:
            continue
        if chave_clean.lower() in CAMPOS_BINARIOS:
            continue
        if isinstance(valor, str) and "(Binary data" in valor:
            continue
        resultado[chave_clean] = valor
    return resultado


def extrair_metadados(conteudo: bytes, nome_arquivo: str) -> dict[str, Any]:
    tipo = _detectar_tipo(nome_arquivo)
    suffix = Path(nome_arquivo).suffix

    with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
        tmp.write(conteudo)
        tmp_path = tmp.name

    meta: dict[str, Any] = {}
    try:
        with exiftool.ExifToolHelper() as et:
            dados_brutos = et.get_metadata(tmp_path)
            meta = _normalizar(dados_brutos[0]) if dados_brutos else {}
    except Exception as exc:
        logger.error("Falha ao extrair metadados com ExifTool: %s", exc)
    finally:
        os.unlink(tmp_path)

    meta["_file_name"] = nome_arquivo
    meta["_file_type"] = tipo
    meta["_file_size_kb"] = round(len(conteudo) / 1024, 2)

    return meta


def ela(conteudo: bytes, sufixo: str) -> str:
    imagem_original = Image.open(io.BytesIO(conteudo)).convert("RGB")

    buffer_recomp = io.BytesIO()
    imagem_original.save(buffer_recomp, format="JPEG", quality=ELA_QUALIDADE)
    buffer_recomp.seek(0)
    imagem_recomprimida = Image.open(buffer_recomp).convert("RGB")

    diferenca = ImageChops.difference(imagem_original, imagem_recomprimida)
    arr = np.array(diferenca, dtype=np.float32)
    arr = np.clip(arr * ELA_FATOR_AMPLIFICACAO, 0, ELA_VALOR_MAX).astype(np.uint8)

    imagem_ela = Image.fromarray(arr)
    buffer_saida = io.BytesIO()
    imagem_ela.save(buffer_saida, format="PNG")

    return base64.b64encode(buffer_saida.getvalue()).decode()


def verificar_c2pa(conteudo: bytes, sufixo: str) -> dict[str, Any]:
    resultado_padrao: dict[str, Any] = {
        "presente": False,
        "valido": False,
        "assinante": None,
        "software": None,
        "acao": None,
    }

    with tempfile.NamedTemporaryFile(delete=False, suffix=sufixo) as tmp:
        tmp.write(conteudo)
        tmp_path = tmp.name

    try:
        try:
            proc = subprocess.run(
                ["c2patool", tmp_path],
                capture_output=True,
                text=True,
                timeout=C2PA_TIMEOUT_S,
            )
            if proc.returncode != 0:
                return resultado_padrao

            dados = json.loads(proc.stdout)
        except FileNotFoundError:
            logger.warning("c2patool nao encontrado no PATH")
            return resultado_padrao
        except (subprocess.TimeoutExpired, json.JSONDecodeError, Exception) as exc:
            logger.error("Falha ao executar c2patool: %s", exc)
            return resultado_padrao

        manifests = dados.get("manifests", {})
        if not manifests:
            return resultado_padrao

        primeiro = next(iter(manifests.values()))
        assinante = primeiro.get("signature_info", {}).get("issuer")
        software = primeiro.get("claim_generator")

        acao = None
        for assertion in primeiro.get("assertions", []):
            if str(assertion.get("label", "")).startswith("c2pa.actions"):
                acoes_lista = assertion.get("data", {}).get("actions", [])
                if acoes_lista:
                    acao = acoes_lista[0].get("action")
                break

        return {
            "presente": True,
            "valido": True,
            "assinante": assinante,
            "software": software,
            "acao": acao,
        }
    finally:
        os.unlink(tmp_path)


def reverse_search(conteudo: bytes) -> list[dict[str, Any]]:
    api_key = os.environ.get("SERPAPI_KEY", "")
    if not api_key:
        raise ValueError("A chave de API da SerpApi (SERPAPI_KEY) nao foi configurada no ambiente.")

    data = {
        "engine": SERPAPI_ENGINE,
        "api_key": api_key,
    }
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
    }

    try:
        resposta = requests.post(
            SERPAPI_URL,
            data=data,
            files={"image": conteudo},
            headers=headers,
            timeout=30,
        )
        resposta.raise_for_status()
        dados = resposta.json()

        if "error" in dados:
            raise Exception("Erro da API SerpApi")

        resultados_brutos = dados.get("image_results", [])[:SERPAPI_MAX_RESULTADOS]
        return [
            {"titulo": item.get("title"), "url": item.get("link"), "data": item.get("date")}
            for item in resultados_brutos
        ]
    except Exception as exc:
        logger.error("Falha na busca reversa via SerpAPI: %s", exc)
        raise Exception("Falha na comunicacao com o servico de busca") from exc


def analise(conteudo: bytes) -> dict[str, Any]:
    try:
        imagem_np = np.frombuffer(conteudo, np.uint8)
        img_cv = cv2.imdecode(imagem_np, cv2.IMREAD_COLOR)
        if img_cv is None:
            return {}

        img_gray = cv2.cvtColor(img_cv, cv2.COLOR_BGR2GRAY)
        img_yuv = cv2.cvtColor(img_cv, cv2.COLOR_BGR2YUV)
        y_channel, _, _ = cv2.split(img_yuv)

        sobel_x = cv2.Sobel(y_channel, cv2.CV_64F, 1, 0, ksize=3)
        sobel_y = cv2.Sobel(y_channel, cv2.CV_64F, 0, 1, ksize=3)
        grad_magnitude = np.sqrt(sobel_x**2 + sobel_y**2)
        grad_normalized = cv2.normalize(
            grad_magnitude, None, 0, 255, cv2.NORM_MINMAX
        ).astype(np.uint8)
        _, buffer_grad = cv2.imencode(".png", grad_normalized)
        grad_b64 = base64.b64encode(buffer_grad).decode("utf-8")

        srm_kernel = np.array([[-1, 2, -1], [2, -4, 2], [-1, 2, -1]]) / 4.0
        noise_residual = cv2.filter2D(img_gray, -1, srm_kernel)

        block_size = 16
        h, w = noise_residual.shape
        n_rows = h // block_size
        n_cols = w // block_size

        heatmap = np.zeros((n_rows, n_cols), dtype=np.float32)
        for r_idx in range(n_rows):
            for c_idx in range(n_cols):
                r = r_idx * block_size
                c = c_idx * block_size
                block = noise_residual[r:r + block_size, c:c + block_size]
                heatmap[r_idx, c_idx] = float(np.var(block))

        overall_variance = float(np.mean(heatmap)) if heatmap.size > 0 else 0.0

        heatmap_norm = cv2.normalize(
            heatmap, None, 0, 255, cv2.NORM_MINMAX
        ).astype(np.uint8)
        heatmap_color = cv2.applyColorMap(heatmap_norm, cv2.COLORMAP_JET)
        heatmap_resized = cv2.resize(
            heatmap_color, (w, h), interpolation=cv2.INTER_NEAREST
        )
        _, buffer_heatmap = cv2.imencode(".png", heatmap_resized)
        noise_heatmap_b64 = base64.b64encode(buffer_heatmap).decode("utf-8")

        fft_b64, fft_simetria = _analisar_fft(img_gray)
        corr_rgb = _correlacao_rgb(img_cv)
        aber_cromatica = _aberracao_cromatica(img_cv)

        return {
            "gradient_map_b64": grad_b64,
            "noise_heatmap_b64": noise_heatmap_b64,
            "noise_variance": round(overall_variance, 4),
            "fft_map_b64": fft_b64,
            "fft_simetria": round(fft_simetria, 4),
            "correlacao_rgb": corr_rgb,
            "aberracao_cromatica": round(aber_cromatica, 4),
        }
    except Exception as exc:
        logger.error("Falha na analise forense avancada: %s", exc)
        return {}


def _analisar_fft(img_gray: np.ndarray) -> tuple[str, float]:
    f = np.fft.fft2(img_gray.astype(np.float32))
    fshift = np.fft.fftshift(f)
    magnitude = np.log1p(np.abs(fshift))

    magnitude_norm = cv2.normalize(magnitude, None, 0, 255, cv2.NORM_MINMAX).astype(np.uint8)
    magnitude_color = cv2.applyColorMap(magnitude_norm, cv2.COLORMAP_INFERNO)
    _, buffer_fft = cv2.imencode(".png", magnitude_color)
    fft_b64 = base64.b64encode(buffer_fft).decode()

    h, w = magnitude.shape
    top_half = magnitude[:h // 2, :]
    bottom_half = np.flipud(magnitude[h // 2:, :])
    min_h = min(top_half.shape[0], bottom_half.shape[0])
    diff = np.abs(top_half[:min_h] - bottom_half[:min_h])
    simetria = float(1.0 - (np.mean(diff) / (np.max(magnitude) + 1e-9)))

    return fft_b64, simetria


def _correlacao_rgb(img_cv: np.ndarray) -> dict[str, float]:
    b, g, r = cv2.split(img_cv.astype(np.float32))

    def corr(a: np.ndarray, b_: np.ndarray) -> float:
        a_flat = a.flatten()
        b_flat = b_.flatten()
        if np.std(a_flat) < 1e-9 or np.std(b_flat) < 1e-9:
            return 1.0
        return float(np.corrcoef(a_flat, b_flat)[0, 1])

    return {
        "rg": round(corr(r, g), 4),
        "rb": round(corr(r, b), 4),
        "gb": round(corr(g, b), 4),
    }


def _aberracao_cromatica(img_cv: np.ndarray) -> float:
    img_suavizada = cv2.GaussianBlur(img_cv, (3, 3), 0)
    b, g, r = cv2.split(img_suavizada)

    edges_r = cv2.Canny(r, 30, 90)
    edges_g = cv2.Canny(g, 30, 90)
    edges_b = cv2.Canny(b, 30, 90)

    mask = (edges_r > 0) | (edges_g > 0) | (edges_b > 0)
    total_pixels = float(np.count_nonzero(mask)) + 1e-9

    diff_rg = np.count_nonzero(cv2.bitwise_xor(edges_r, edges_g) & mask)
    diff_rb = np.count_nonzero(cv2.bitwise_xor(edges_r, edges_b) & mask)
    diff_gb = np.count_nonzero(cv2.bitwise_xor(edges_g, edges_b) & mask)

    desalinhamento_total = float(diff_rg + diff_rb + diff_gb)
    return desalinhamento_total / (2.0 * total_pixels)


def calcular_score_alerta(
    metadados: dict,
    c2pa: dict,
    forense_avancada: dict,
) -> dict[str, Any]:
    score = 0.0
    regras_acionadas = []

    exif_keys = [k for k in metadados.keys() if not k.startswith("_")]
    exif_count = len(exif_keys)

    if exif_count == 0:
        score += 10.0
        regras_acionadas.append("Nenhum metadado EXIF encontrado")
    elif exif_count < 6:
        score += 5.0
        regras_acionadas.append("Poucos metadados EXIF")

    if c2pa.get("presente") and not c2pa.get("valido"):
        score += 25.0
        regras_acionadas.append("Certificado C2PA presente mas invalido")

    variance = forense_avancada.get("noise_variance", 999.0)
    if variance < 3.0:
        score += 20.0
    elif variance < 7.0:
        score += 12.0
    elif variance > 80.0:
        score += 15.0

    fft_simetria = forense_avancada.get("fft_simetria", 0.0)
    if fft_simetria > 0.98:
        score += 15.0

    corr = forense_avancada.get("correlacao_rgb", {})
    media_corr = 0.0
    if corr:
        media_corr = (
            abs(corr.get("rg", 0.0))
            + abs(corr.get("rb", 0.0))
            + abs(corr.get("gb", 0.0))
        ) / 3.0
        if media_corr > 0.92:
            score += 8.0
        if media_corr > 0.98:
            score += 10.0

    aber = forense_avancada.get("aberracao_cromatica", -1.0)
    if aber >= 0.0 and aber < 0.03:
        score += 10.0
    elif aber > 0.20:
        score += 5.0

    if score >= 50.0:
        nivel = "Alto"
    elif score >= 25.0:
        nivel = "Medio"
    else:
        nivel = "Baixo"

    return {
        "score": score,
        "nivel": nivel,
        "regras": regras_acionadas,
    }
